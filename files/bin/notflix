#!/bin/sh -e
# FOSS version of Netflix
# Borrowed from https://github.com/Bugswriter/notflix

if [ "$1" = "download" ]; then
    query=$(echo -n '' | dmenu -p 'Movie: ' | tr ' ' '+')
    [ -z "$query" ] && exit 1

    movie=$(curl -s https://1337x.wtf/search/$query/1/ | grep -Eo "torrent\/[0-9]{7}\/[a-zA-Z0-9?%-]*/" | dmenu -l 15)
    transmission-remote -a "$(curl -s https://1337x.wtf/$movie | grep -Po "magnet:\?xt=urn:btih:[a-zA-Z0-9]*" | head -n 1)"
    "$TERMINAL" -e watch transmission-remote -l
elif [ "$1" = "play" ]; then
    movie="$(ls ~/movies/ | dmenu -p 'Movie: ' -l 10)"
    [ -z "$movie" ] || mpv ~/movies/"$movie"
elif [ "$1" = "stop" ]; then
    movie="$(transmission-remote -l | sed '1d;$d' | dmenu -l 10 | sed 's/^ *\([0-9]\+\).*/\1/g')"
    [ -z "$movie" ] || transmission-remote -t "$movie" -r
else
    echo "Usage: notflix [download|play|stop]"
    exit 1
fi
