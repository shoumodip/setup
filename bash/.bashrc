export PS1="\[\e[1;36m\]\w\[\e[0m\] "

alias ls="ls --color=auto --group-directories-first -h"
alias ll="ls -l"
alias grep="grep --color=auto -inH"

alias v="nvim"
alias mv="mv -vf"
alias cp="cp -vrf"
alias rm="rm -vrf"

alias xi="sudo xbps-install"
alias xr="sudo xbps-remove -R"
alias xs="xbps-query -Rs"
alias mkd="mkdir -p"
